<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>FRUVER | Drivers</title>
    <script src="https://cdn.tailwindcss.com"></script> 
            setTimeout(() => {
                closeAlert();
            }, 6000); // Se oculta sola en 6 segundos

            // 3. Sonido "Tilin" Sintetizado (No requiere mp3, lo crea el navegador)
            if(audioCtx && audioCtx.state !== 'suspended') {
                try {
                    const osc = audioCtx.createOscillator();
                    const gainNode = audioCtx.createGain();
                    
                    osc.connect(gainNode);
                    gainNode.connect(audioCtx.destination);
                    
                    osc.type = 'sine'; // Sonido suave
                    osc.frequency.setValueAtTime(880, audioCtx.currentTime); // Frecuencia alta (Campana)
                    osc.frequency.exponentialRampToValueAtTime(440, audioCtx.currentTime + 0.5);
                    
                    gainNode.gain.setValueAtTime(0.5, audioCtx.currentTime);
                    gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.5);
                    
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.5);
                } catch(err) { console.log("Audio no soportado"); }
            }
        }

        function closeAlert() {
            document.getElementById('new-order-alert').classList.remove('alert-slide-down');
        }


        function switchTab(tab) {
            currentTab = tab;
            document.querySelectorAll('.nav-btn').forEach(b => {
                b.classList.remove('active', 'text-emerald-400');
                b.classList.add('text-slate-500');
            });
            const activeBtn = document.getElementById('nav-'+tab);
            if(activeBtn) {
                activeBtn.classList.add('active', 'text-emerald-400');
                activeBtn.classList.remove('text-slate-500');
            }
            document.querySelectorAll('.view-section').forEach(v => v.classList.add('hidden'));
            document.getElementById('view-'+tab).classList.remove('hidden');
            
            if(tab === 'profile') loadDriverProfile();
            else loadOrders();
        }

        function renderView(tab, data) {
            if(tab === 'profile') return;
            const list = tab === 'active' ? data.active : data.pool; 
            const container = document.getElementById('view-'+tab);
            const isMyRoute = tab === 'active';
            
            if(!list || list.length === 0) {
                let txt = isMyRoute ? "Sin ruta activa" : "No hay pedidos nuevos";
                container.innerHTML = `<div class="flex flex-col items-center justify-center h-[50vh] text-slate-600 select-none"><i class="fas ${isMyRoute ? 'fa-route' : 'fa-box-open'} text-6xl mb-6 opacity-30"></i><p class="font-bold text-sm tracking-widest uppercase opacity-50">${txt}</p></div>`;
                return;
            }

            container.innerHTML = list.map(o => {
                const mapLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(o.direccion)}`;
                let cardStyle = isMyRoute ? 'card-active' : 'card-pending';

                let botones = '';
                if(isMyRoute) {
                    botones = `
                        <div class="grid grid-cols-4 gap-3">
                            <button onclick="openFailModal(${o.id_pedido})" class="col-span-1 py-4 rounded-2xl bg-slate-800 border border-slate-700 text-red-400 font-bold text-xl hover:bg-red-500 hover:text-white transition"><i class="fas fa-triangle-exclamation"></i></button>
                            <button onclick="openDeliveryModal(${o.id_pedido})" class="col-span-3 py-4 rounded-2xl bg-emerald-500 text-slate-900 font-black text-sm uppercase tracking-wider shadow-lg shadow-emerald-500/20 hover:bg-emerald-400 transition flex items-center justify-center gap-2">
                                <i class="fas fa-file-signature text-lg"></i> Entregar
                            </button>
                        </div>`;
                } else {
                    botones = `
                        <button onclick="updateStatus(${o.id_pedido}, 'En Ruta')" class="w-full py-4 rounded-2xl bg-blue-600 text-white font-bold text-sm uppercase tracking-wider shadow-lg shadow-blue-500/20 hover:bg-blue-500 transition flex items-center justify-center gap-2">
                            ACEPTAR PEDIDO <i class="fas fa-hand-holding-box text-lg"></i>
                        </button>`;
                }

                return `
                <div class="${cardStyle} p-5 rounded-3xl mb-4 fade-in relative overflow-hidden shadow-lg">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <h3 class="font-black text-white text-lg leading-tight mb-1">${o.cliente_nombre}</h3>
                            <span class="text-[10px] font-bold bg-slate-900/50 text-slate-300 px-2 py-1 rounded-lg font-mono border border-slate-700/50">#${o.id_pedido}</span>
                        </div>
                        ${isMyRoute ? `<a href="${mapLink}" target="_blank" class="w-12 h-12 rounded-2xl bg-blue-500/20 text-blue-400 border border-blue-500/30 flex items-center justify-center hover:bg-blue-500 hover:text-white transition shadow-lg"><i class="fas fa-location-arrow text-lg"></i></a>` : ''}
                    </div>
                    <div class="flex items-start gap-3 mb-6 bg-black/20 p-4 rounded-2xl border border-white/5">
                        <i class="fas fa-map-pin text-red-400 mt-1"></i>
                        <p class="text-sm font-medium text-slate-300 leading-snug">${o.direccion}</p>
                    </div>
                    ${botones}
                </div>`;
            }).join('');
        }

        async function updateStatus(id, status, note='', firma=null) {
            const body = {id:id, status:status, nota:note, id_repartidor: window.myDriverId};
            if(firma) body.firma = firma;
            await fetch(`${API}?action=update_status`, {method:'POST', body:JSON.stringify(body)});
            loadOrders();
        }
        
        function openFailModal(id) { failId = id; document.getElementById('modal-fail').showModal(); }
        async function setFailReason(reason, newStatus) { await updateStatus(failId, newStatus, reason); document.getElementById('modal-fail').close(); }
    </script>
</body>
</html>